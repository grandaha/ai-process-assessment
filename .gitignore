.DS_Store
*.swp
*.swo

# Local Claude Code settings
.claude/

# Session handoff / personal logs
.remember/

# Client engagement data — engagement folders live at the project root.
# Add each engagement folder by name (e.g. acme-corp/).
# The bundled sample run lives here:
sample-pso-delivery/

# Internal planning and design docs (specs + plans are tracked so they travel
# with the repo; any other local-only content under docs/superpowers/ stays ignored).
docs/superpowers/*
!docs/superpowers/specs/
!docs/superpowers/plans/

# Subagent staging area
_staging/

# Python (test suite artifacts)
__pycache__/
*.py[cod]
.pytest_cache/

# Python virtual environment
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Release build artifacts (zips live on GitHub Releases, never in the repo)
*.zip
